// Prisma Client: genera el cliente TypeScript que usarás en el código (PrismaClient)
generator client {
  provider = "prisma-client-js"
}

// Datasource: define a qué motor de BD se conecta Prisma
datasource db {
  provider = "postgresql"
}

// Enum de roles (para autorización / permisos)
enum UserRole {
  ADMIN
  DOCTOR
  SECRETARY
}

// Enum de estado del usuario (para bloquear acceso, pendientes, etc.)
enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

// Enum del estado de un usuario en una clínica
enum ClinicMembershipStatus {
  ACTIVE
  INACTIVE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  WAIVED
}

enum ObservationStatus {
  PRELIMINARY
  FINAL
  AMENDED
  ENTERED_IN_ERROR
}

enum ObservationValueType {
  STRING
  QUANTITY
  BOOLEAN
}

enum InternalAlertType {
  APPOINTMENT_CREATED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_CANCELLED
  APPOINTMENT_CONFLICT
  PAYMENT_PENDING
  CUSTOM
}

enum InternalAlertDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum FhirLinkResourceType {
  PATIENT
  APPOINTMENT
  ENCOUNTER
  OBSERVATION
}

model User {
  // ID principal, generado como cuid() (string único, amigable para frontend)
  id String @id @default(cuid())

  // Email como username principal, único en la BD
  email String @unique
  
  // Campos típicos que usa Auth.js/NextAuth (no son obligatorios para auth propia)
  // name: nombre visible (por ejemplo si tuvieras OAuth o datos básicos)
  name          String?
  // image: foto/avatar del usuario
  image         String?
  // emailVerified: fecha/hora en que se verificó el correo (si implementas verificación)
  emailVerified DateTime?

  // Tu auth real por credenciales
  // passwordHash: hash de contraseña (bcrypt/argon2). Es optional porque:
  // - podrías tener usuarios creados por OAuth sin contraseña
  // - o flujos futuros como magic links
  passwordHash String?

  // Fuerza cambio de contraseÃ±a al primer inicio de sesiÃ³n
  mustChangePassword Boolean @default(false)

  // Rol del usuario (por defecto ADMIN mientras estás en MVP)
  role UserRole @default(ADMIN)

  // Estado del usuario (por defecto ACTIVE)
  status UserStatus @default(ACTIVE)

  // Auditoría mínima
  createdAt   DateTime  @default(now()) // cuándo se creó el registro
  updatedAt   DateTime  @updatedAt // se actualiza solo en cada update
  lastLoginAt DateTime? // útil para auditoría/seguridad

  // Relación 1 a 1 con los datos personales (separación auth vs perfil)
  // UserProfile tiene userId UNIQUE, por eso aquí es "profile?" (0 o 1 perfil)
  profile UserProfile?

  // Relaciones usadas por Auth.js/NextAuth si guardas sesiones en base de datos
  // - sessions: permite múltiples sesiones simultáneas (mismo usuario en varios dispositivos)
  // - accounts: para vincular proveedores OAuth (Google, Apple, etc.)
  sessions             Session[]
  accounts             Account[]
  clinicMemberships    ClinicMembership[]
  doctorProfile        DoctorProfile?
  appointmentsAsDoctor Appointment[]      @relation("AppointmentDoctor")
  appointmentsCreated  Appointment[]      @relation("AppointmentCreatedBy")
  observationsAsDoctor Observation[]      @relation("ObservationDoctor")
  clinicalVisits       ClinicalVisit[]
  internalAlertsCreated InternalAlert[]          @relation("InternalAlertCreatedBy")
  internalAlertsAsDoctor InternalAlert[]         @relation("InternalAlertDoctor")
  internalAlertReceipts InternalAlertRecipient[]
}

model UserProfile {
  // ID del perfil
  id String @id @default(cuid())

  // FK hacia User. UNIQUE => asegura 1 perfil por usuario (relación 1:1)
  userId String @unique

  // Datos personales (no auth)
  firstName String
  lastName  String
  phone     String?

  // RUT opcional y único si lo usas (ojo: en la vida real puede requerir normalización)
  rut String? @unique

  // Auditoría
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación: este perfil pertenece a un User
  // onDelete: Cascade => si borras el User, se borra automáticamente el profile
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Modelos estándar del Prisma Adapter de Auth.js/NextAuth ------------------
// Útiles si quieres que Auth.js administre sesiones/OAuth/verificación.

model Account {
  // ID interno del vínculo
  id String @id @default(cuid())

  // FK al usuario dueño de esta cuenta externa
  userId String

  // Campos propios de OAuth / providers
  type              String // tipo de cuenta (ej: "oauth")
  provider          String // ej: "google"
  providerAccountId String // id del usuario en el provider

  // Tokens que algunos providers entregan (opcionales)
  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  // Relación al User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Evita duplicados: un mismo providerAccountId no puede repetirse para ese provider
  @@unique([provider, providerAccountId])
}

model Session {
  // ID interno de la sesión
  id String @id @default(cuid())

  // Token de sesión (lo que se guarda en cookie/cliente como referencia)
  sessionToken String @unique

  // FK al usuario
  userId String

  // Fecha/hora de expiración
  expires DateTime

  // Relación al User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  // identifier suele ser email u otro identificador del usuario
  identifier String

  // token único (para verificación de email o magic links)
  token String @unique

  // cuándo expira el token
  expires DateTime

  // combinación única (regla típica de Auth.js)
  @@unique([identifier, token])
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  city      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships    ClinicMembership[]
  patients       Patient[]
  boxes          Box[]
  appointments   Appointment[]
  clinicalVisits ClinicalVisit[]
  observations   Observation[]
  internalAlerts InternalAlert[]
  fhirLinks      FhirLink[]
}

model ClinicMembership {
  id        String                 @id @default(cuid())
  userId    String
  clinicId  String
  status    ClinicMembershipStatus @default(ACTIVE)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([userId, status])
}

model Patient {
  id                    String    @id @default(cuid())
  clinicId              String
  firstName             String
  lastName              String
  secondLastName        String?
  run                   String
  runNormalized         String
  email                 String?
  phone                 String?
  birthDate             DateTime?
  gender                String?
  address               String?
  city                  String?
  emergencyContactName  String?
  emergencyContactPhone String?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  clinic         Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments   Appointment[]
  clinicalVisits ClinicalVisit[]
  observations   Observation[]
  patientTreatments PatientTreatment[]

  @@index([clinicId, isActive])
  @@unique([clinicId, runNormalized])
  @@index([clinicId, lastName])
}

model DoctorProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  rut           String
  rutNormalized String   @unique
  specialty     String?
  bio           String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Box {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([clinicId, name])
  @@index([clinicId, isActive])
}

model Appointment {
  id            String            @id @default(cuid())
  clinicId      String
  patientId     String
  doctorId      String
  boxId         String
  startAt       DateTime
  endAt         DateTime
  status        AppointmentStatus @default(SCHEDULED)
  paymentStatus PaymentStatus     @default(PENDING)
  notes         String?
  createdBy     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  clinic         Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor         User            @relation("AppointmentDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  box            Box             @relation(fields: [boxId], references: [id], onDelete: Restrict)
  createdByUser  User?           @relation("AppointmentCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  clinicalVisits ClinicalVisit[]

  @@index([clinicId, startAt])
  @@index([doctorId, startAt])
  @@index([boxId, startAt])
  @@index([patientId, startAt])
}

model FhirLink {
  id               String               @id @default(cuid())
  clinicId         String
  resourceType     FhirLinkResourceType
  internalId       String
  fhirId           String
  identifierSystem String?
  identifierValue  String?
  identifierKey    String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, resourceType, internalId])
  @@unique([clinicId, resourceType, fhirId])
  @@unique([clinicId, resourceType, identifierKey])
  @@index([clinicId, resourceType, createdAt])
}

model Observation {
  id              String               @id @default(cuid())
  clinicId        String
  patientId       String
  doctorId        String
  clinicalVisitId String?
  status          ObservationStatus    @default(FINAL)
  code            String
  codeSystem      String
  codeDisplay     String?
  categoryCode    String?
  categorySystem  String?
  categoryDisplay String?
  valueType       ObservationValueType
  valueString     String?
  valueQuantity   Float?
  valueBoolean    Boolean?
  valueUnit       String?
  effectiveAt     DateTime             @default(now())
  issuedAt        DateTime             @default(now())
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor       User          @relation("ObservationDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  clinicalVisit ClinicalVisit? @relation(fields: [clinicalVisitId], references: [id], onDelete: SetNull)

  @@index([clinicId, patientId, effectiveAt])
  @@index([clinicId, code, effectiveAt])
  @@index([doctorId, effectiveAt])
  @@index([clinicalVisitId, effectiveAt])
}

model AuditLog {
  // Registro de auditoría: eventos relevantes del sistema
  id         String   @id @default(cuid())
  // Fecha y hora en que ocurrió el evento
  occurredAt DateTime @default(now())
  // Qué ocurrió (nombre o descripción breve del evento)
  event      String
  // Responsable/autor del evento (usuario o sistema) (Se usara el correo sacado de la sesión)
  author     String
  // Detalle opcional del evento
  detail     String?
}

model InternalAlert {
  id            String            @id @default(cuid())
  clinicId       String
  createdById    String
  doctorId       String?
  eventType      InternalAlertType @default(CUSTOM)
  title          String
  message        String
  referenceType  String?
  referenceId    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  clinic     Clinic                  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdBy  User                    @relation("InternalAlertCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  doctor     User?                   @relation("InternalAlertDoctor", fields: [doctorId], references: [id], onDelete: SetNull)
  recipients InternalAlertRecipient[]

  @@index([clinicId, createdAt])
  @@index([createdById, createdAt])
  @@index([doctorId, createdAt])
}

model InternalAlertRecipient {
  id             String                      @id @default(cuid())
  alertId        String
  userId         String
  deliveryStatus InternalAlertDeliveryStatus @default(PENDING)
  deliveryError  String?
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  alert InternalAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([alertId, userId])
  @@index([userId, readAt, createdAt])
  @@index([deliveryStatus, createdAt])
}

model Treatment {
  // Tratamientos disponibles en la clínica y su precio
  id    String  @id @default(cuid())
  // Nombre del tratamiento
  name  String  @unique
  // Precio del tratamiento
  price Decimal @db.Decimal(10, 2)
  patientTreatments PatientTreatment[]
}

model PatientTreatment {
  id          String    @id @default(cuid())
  patientId   String
  treatmentId String
  performedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  patient   Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatment Treatment       @relation(fields: [treatmentId], references: [id], onDelete: Restrict)
  payments  PaymentHistory[]

  @@index([patientId, performedAt])
  @@index([treatmentId])
}

model PaymentHistory {
  id                 String        @id @default(cuid())
  patientTreatmentId String
  recordedAt         DateTime      @default(now())
  status             PaymentStatus @default(PENDING)
  amount             Decimal       @db.Decimal(10, 2)
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  patientTreatment PatientTreatment @relation(fields: [patientTreatmentId], references: [id], onDelete: Cascade)

  @@index([patientTreatmentId, recordedAt])
  @@index([status])
}

model ClinicalVisit {
  id            String   @id @default(cuid())
  clinicId      String
  patientId     String
  doctorId      String
  appointmentId String?
  startedAt     DateTime @default(now())
  createdAt     DateTime @default(now())

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor      User         @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  observations Observation[]

  @@index([clinicId, doctorId, startedAt])
  @@index([clinicId, patientId, startedAt])
}
